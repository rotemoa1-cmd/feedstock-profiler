# ============================================================
# Feedstock Characterizer - Configuration
# ============================================================
# Copy this file to .env and fill in your settings.
# The app auto-detects which backend to use:
#   - If ANTHROPIC_API_KEY is set → uses Claude (cloud)
#   - Otherwise → uses Ollama (local, free)
# You can override auto-detection with BACKEND=anthropic|ollama

# --- Option A: Anthropic (Claude) ---
# Get your key at console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_api_key_here

# --- Option B: Ollama (free, local, no API key needed) ---
# Install from ollama.com, then run: ollama pull llama3.2
# Uncomment and change the model name if desired:
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# --- Force a specific backend (optional) ---
# BACKEND=ollama
# BACKEND=anthropic
